page {
  min-height: 100vh;
  background: #f6f8f5;
  color: #243226;
  font-size: 28rpx;
}

.container {
  padding: 32rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(35, 64, 38, 0.08);
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.text-muted {
  color: #6d786f;
  line-height: 1.7;
}

.primary-button {
  background: #2f7d32;
  color: #ffffff;
  border-radius: 999rpx;
  font-size: 30rpx;
  margin-top: 24rpx;
}

.secondary-button {
  background: #e8f3e8;
  color: #2f7d32;
  border-radius: 999rpx;
  font-size: 30rpx;
  margin-top: 20rpx;
}
