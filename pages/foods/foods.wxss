.food-card {
  padding-bottom: 24rpx;
}

.food-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.food-name {
  font-size: 34rpx;
  font-weight: 700;
}

.food-tag {
  display: inline-block;
  margin-top: 10rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  color: #2f7d32;
  background: #e8f3e8;
  font-size: 24rpx;
}

.add-button {
  background: #2f7d32;
  color: #ffffff;
  border-radius: 999rpx;
}

.food-desc {
  margin-top: 18rpx;
}

.nutrition-list {
  display: flex;
  flex-wrap: wrap;
  margin-top: 18rpx;
  gap: 12rpx;
}

.nutrition-item {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #f0f5f0;
  color: #415244;
  font-size: 24rpx;
}
