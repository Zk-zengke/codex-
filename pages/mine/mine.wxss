.profile-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 108rpx;
  height: 108rpx;
  line-height: 108rpx;
  text-align: center;
  border-radius: 32rpx;
  background: #2f7d32;
  color: #ffffff;
  font-size: 48rpx;
  font-weight: 700;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  color: #415244;
}
