.hero {
  background: linear-gradient(135deg, #e9f7ea, #ffffff);
}

.photo-card {
  overflow: hidden;
}

.xiaoke-photo {
  width: 100%;
  height: 680rpx;
  display: block;
  border-radius: 20rpx;
  background: #eef2ee;
}

.photo-tip {
  margin-top: 14rpx;
  font-size: 24rpx;
}

.meal-item {
  display: flex;
  flex-direction: column;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #eef2ee;
}

.meal-item:last-child {
  border-bottom: 0;
}

.meal-name {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.tip-item {
  color: #415244;
  line-height: 1.8;
  margin: 8rpx 0;
}
